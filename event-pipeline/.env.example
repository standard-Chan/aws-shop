# Producer와 Consumer가 접속할 Kafka 클러스터 bootstrap server 목록이다.
KAFKA_BOOTSTRAP_SERVERS=localhost:19092,localhost:19093,localhost:19094

# 사용자 행동 이벤트 Producer API 서버의 HTTP 포트다.
EVENT_PRODUCER_PORT=18081

# DB Consumer 서버의 HTTP 포트다. 비웹 실행 모드에서는 포트를 열지 않는다.
EVENT_DB_CONSUMER_PORT=18082

# Hadoop Consumer 서버의 HTTP 포트다. 비웹 실행 모드에서는 포트를 열지 않는다.
EVENT_HADOOP_CONSUMER_PORT=18084

# Producer 인스턴스별 Snowflake node id다. 수평 확장 시 인스턴스마다 다른 값을 사용해야 한다.
EVENT_PRODUCER_NODE_ID=1

# 사용자 행동 이벤트 타입별 Kafka topic 이름이다.
EVENT_TOPIC_SEARCH=search-events
EVENT_TOPIC_PRODUCT_VIEW=product-view-events
EVENT_TOPIC_CART=cart-events
EVENT_TOPIC_PURCHASE=purchase-events

# DB Consumer가 이벤트를 저장할 대상 datasource와 schema 생성 전략이다.
EVENT_DB_URL=jdbc:mysql://localhost:3306/aws_shop?serverTimezone=UTC&characterEncoding=UTF-8
EVENT_DB_USERNAME=root
EVENT_DB_PASSWORD=
EVENT_DB_DDL_AUTO=update

# DB 저장용 Consumer group이다. Hadoop/Connect consumer group과 분리해야 한다.
EVENT_DB_CONSUMER_GROUP_ID=analytics-db-consumer-group

# Hadoop 적재용 Consumer group과 로컬 staging 파일 경로다.
EVENT_HADOOP_CONSUMER_GROUP_ID=analytics-hadoop-consumer-group
EVENT_HADOOP_OUTPUT_PATH=/tmp/aws-shop-event-pipeline/user-behavior-events.jsonl
