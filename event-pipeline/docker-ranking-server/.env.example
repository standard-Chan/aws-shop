# Product Ranking server port exposed inside the container.
EVENT_PRODUCT_RANKING_PORT=8080

# Keep this image self-contained. With Redis disabled, rankings are stored in memory.
EVENT_PRODUCT_RANKING_REDIS_ENABLED=false

# ClickHouse
EVENT_PRODUCT_RANKING_CLICKHOUSE_ENABLED=false
EVENT_PRODUCT_RANKING_CLICKHOUSE_URL=jdbc:clickhouse://localhost:8123/default?compress=0
EVENT_PRODUCT_RANKING_CLICKHOUSE_USERNAME=default
EVENT_PRODUCT_RANKING_CLICKHOUSE_PASSWORD=

# Batch write settings for the in-memory ranking store.
EVENT_PRODUCT_RANKING_BATCH_SIZE=5000
EVENT_PRODUCT_RANKING_BATCH_FLUSH_INTERVAL_MILLIS=3000
EVENT_PRODUCT_RANKING_BATCH_QUEUE_CAPACITY=500000

# JVM memory policy. Override this on small remote machines if needed.
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75